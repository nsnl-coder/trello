# Repo-root .env — the SINGLE env file for LOCAL development (docker via
# `make local`, or host-side `pnpm --filter backend dev`; both read this file).
# Copy to .env and fill in. NEVER commit .env (gitignored).
#
# Keys are PLAIN — tiers differ by VALUE, not key name. Deployed tiers never
# see this file: the deploy workflows write /opt/trello/.env on the VPS from
# GitHub secrets/vars using these same key names (see
# .github/workflows/deploy-stage.yml and packages/infra/DEPLOY.md).

# ---- required ---------------------------------------------------------------
# Signing secrets (min 32 chars): openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ---- infra (compose interpolation; sensible local defaults) ------------------
#POSTGRES_PASSWORD=postgres
#MINIO_ACCESS_KEY=minioadmin
#MINIO_SECRET_KEY=minioadmin

# ---- optional: bootstrap super admin (seeded on backend startup) -------------
#SUPER_ADMIN_EMAIL=
#SUPER_ADMIN_PASSWORD=

# ---- optional: outgoing mail (Mailtrap sandbox; unset -> emails not sent) ----
#MAIL_USER=
#MAIL_PASS=

# ---- optional: Google sign-in (empty -> feature disabled) --------------------
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/oauth/google/callback

# ---- optional: admin backup to Google Drive (empty -> feature disabled) ------
#GDRIVE_CLIENT_ID=
#GDRIVE_CLIENT_SECRET=
#GDRIVE_REDIRECT_URI=http://localhost:5173/api/admin/backup/gdrive/callback
#BACKUP_ENCRYPTION_PASSPHRASE=

# ---- optional: error tracking (usually left off locally) ---------------------
#SENTRY_DSN=
