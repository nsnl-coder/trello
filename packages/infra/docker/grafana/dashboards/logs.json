{
  "uid": "logs-overview",
  "title": "Logs overview (Loki)",
  "tags": ["kanbandiv", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "current": { "text": "backend", "value": "backend" },
        "includeAll": false,
        "refresh": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error/fatal log rate ($service)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "logs", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"$service\"} | json | level >= 50 [1m]))",
          "legendFormat": "errors/min"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Errors ($service)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 7 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"$service\"} | json | level >= 50"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "All logs ($service)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 18 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"$service\"}"
        }
      ]
    }
  ]
}
